// cidx.dl — example reasoning script. All vocabulary comes from the shared prelude;
// this file only declares which results to materialize. Copy it as a template for new
// reasoning: `#include "cidx_base.dl"`, write your rules, `.output` them.
//
// Run from the directory holding graph.db:  souffle /path/to/cidx.dl
#include "cidx_base.dl"

.output subtype(IO=sqlite, dbname="index.db")
.output edep(IO=sqlite, dbname="index.db")
.output reach(IO=sqlite, dbname="index.db")
